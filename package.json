{
  "name": "@lwmacct/260706-action-gh-release",
  "version": "0.9.260707",
  "description": "Download, verify, extract, cache, and add a GitHub release binary to PATH",
  "main": "dist/index.js",
  "exports": "./dist/index.js",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "rm -rf dist/* && rollup -c && printf '{\"type\":\"module\"}\\n' > dist/package.json",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "npm": "please-use-pnpm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lwmacct/260706-action-gh-release.git"
  },
  "keywords": [
    "github-actions",
    "github-release",
    "binary-installer"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/lwmacct/260706-action-gh-release/issues"
  },
  "homepage": "https://github.com/lwmacct/260706-action-gh-release#readme",
  "dependencies": {
    "@actions/cache": "^6.1.0",
    "@actions/core": "^3.0.1",
    "@actions/tool-cache": "^4.0.0",
    "@protobuf-ts/runtime": "2.11.1",
    "supports-color": "^10.2.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^26.1.0",
    "rollup": "^4.62.2",
    "terser": "^5.48.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}
